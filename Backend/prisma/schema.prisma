generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  name      String?
  password  String      
  avatarUrl String?
  createdAt DateTime    @default(now())
  
  // NOTE: the relation name is pinned to Prisma's original implicit default so the
  // existing "_DashboardToUser" join table is preserved. Renaming it would drop
  // every membership.
  dashboards      Dashboard[] @relation("DashboardToUser")
  ownedDashboards Dashboard[] @relation("DashboardOwner")
  comments        Comment[]
}

model Dashboard {
  id        String   @id @default(uuid())
  name      String
  accessKey String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Nullable so existing rows migrate cleanly; backfilled to each workspace's
  // earliest member. Only the owner may delete a workspace.
  ownerId String?
  owner   User?   @relation("DashboardOwner", fields: [ownerId], references: [id])

  members    User[]     @relation("DashboardToUser")
  bugs       Bug[]
  activities Activity[]
}

model Bug {
  id          String    @id @default(uuid())
  title       String
  description String    // Supports Markdown
  
  severity    Severity
  status      BugStatus @default(OPEN)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id])
  comments    Comment[]
}

model Activity {
  id          String    @id @default(uuid())
  text        String
  type        String    // e.g., "BUG_CREATED", "BUG_RESOLVED"
  createdAt   DateTime  @default(now())

  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id])
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  bugId     String
  bug       Bug      @relation(fields: [bugId], references: [id])
}

enum Severity {
  Pending // awaiting AI classification (or classification failed)
  High
  Normal
  Low
}

enum BugStatus {
  OPEN
  RESOLVED
}